# ===========================================
# SHIELD CHAT - Local Development Configuration
# ===========================================
# IMPORTANT: This file is for LOCAL DEVELOPMENT ONLY
# In production (Render), use their environment variables
# ===========================================

# ===========================================
# Server Configuration
# ===========================================
PORT=10000
NODE_ENV=development

# ===========================================
# Database Configuration (PostgreSQL Local)
# ===========================================
DATABASE_URL=postgresql://shield_chat_db_user:VQNpBtVC2Gluo8fyszZtnLqnTaF5uk3k@dpg-d67mv4o6fj8s73drdhfg-a.oregon-postgres.render.com/shield_chat_db

# ===========================================
# Security Configuration
# ===========================================
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=1h

# AES-256 Encryption Key (MUST BE EXACTLY 32 CHARACTERS)
ENCRYPTION_KEY=shield_chat_super_secret_2026_key

# ===========================================
# CORS Configuration
# ===========================================
FRONTEND_URL=http://localhost:10000

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# Session Configuration
# ===========================================
SESSION_SECRET=your_session_secret_change_in_production

# ===========================================
# File Upload Configuration
# ===========================================
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./public/uploads

# ===========================================
# Log Configuration
# ===========================================
LOG_LEVEL=info
LOG_DIR=./logs
